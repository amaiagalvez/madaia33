{
    "preset": "laravel",
    "exclude": [
        "vendor",
        "node_modules",
        "dc-data",
        ".git"
    ],
    "rules": {
        "indentation_type": true,
        "ordered_imports": {
            "sort_algorithm": "length"
        },
        "single_import_per_statement": true,
        "single_line_after_imports": true,
        "blank_line_after_opening_tag": true,
        "no_trailing_whitespace": true,
        "braces_position": true
    }
}
