<?xml version="1.0"?>
<ruleset name="Project Quality Rules"
    xmlns="http://pmd.sf.net/ruleset/1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>
        Enforces maintainability limits for method/class size and complexity.
    </description>

    <!-- CyclomaticComplexity: Allow up to 12 for complex business logic in votings/forms -->
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="12"/>
        </properties>
    </rule>

    <!-- NPathComplexity: Keep strict; no refactored methods should hit this -->
    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="200"/>
        </properties>
    </rule>

    <!-- ExcessiveMethodLength: Increased to 50 for Livewire component methods (render, mount) and complex business logic -->
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="50"/>
        </properties>
    </rule>

    <!-- ExcessiveParameterList: Increased to 6 for action methods with optional parameters -->
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="6"/>
        </properties>
    </rule>

    <!-- ExcessiveClassLength: Increased to 500 for large Livewire components (forms with multiple sections) -->
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="500"/>
        </properties>
    </rule>

    <!-- CouplingBetweenObjects: Increased to 20 (ServiceProviders and complex Livewire components are inherently coupled) -->
    <rule ref="rulesets/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="maximum" value="20"/>
        </properties>
    </rule>
</ruleset>
