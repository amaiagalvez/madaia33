flowchart TB
  subgraph INFRA["Infrastructure and Runtime"]
    DOCKER["docker-compose.yml"]
    APPC["madaia33 container | PHP 8.4 + Apache"]
    DBC["db container | MariaDB 11.7"]
    VITE["vite.config.js"]
    CSS["resources/css/app.css | Tailwind v4 + Flux tokens"]
    JS["resources/js/app.js | minimal entry"]

    DOCKER --> APPC
    DOCKER --> DBC
    VITE --> CSS
    VITE --> JS
  end

  subgraph ENTRY["HTTP Entry"]
    WEB["routes/web.php"]
    SETTINGS["routes/settings.php"]
