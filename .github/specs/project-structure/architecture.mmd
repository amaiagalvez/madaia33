      NOTICEM["Notice"]
      IMAGEM["Image"]
      MSGM["ContactMessage"]
      SETTINGM["Setting"]
      LOCM["NoticeLocation"]
    end

    subgraph DOMAIN["Validation Rules and Support"]
      VALID["app/Validations | AdminSettingsValidation ContactFormValidation"]
      RULES["app/Rules | NoScriptTags"]
      SUPPORT["app/Support | ConfiguredMailSettings"]
      ACTIONS["app/Actions/Fortify | CreateNewUser ResetUserPassword"]
    end

    subgraph MAIL["Mailables"]
      ABSTRACTMAIL["AbstractContactMail"]
      CONFMAIL["ContactConfirmation"]
      NOTIFMAIL["ContactNotification"]
      TESTMAIL["TestEmail"]
    end

